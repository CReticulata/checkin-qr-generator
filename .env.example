# Google OAuth 憑證
# 從 https://console.cloud.google.com/apis/credentials 取得
# 1. 建立新專案或選擇現有專案
# 2. 啟用 Google+ API
# 3. 建立 OAuth 2.0 用戶端 ID 憑證
# 4. 新增授權重新導向 URI：http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=你的_google_client_id
GOOGLE_CLIENT_SECRET=你的_google_client_secret

# NextAuth 設定
# 為 NEXTAUTH_SECRET 產生安全的隨機字串
# 可使用：openssl rand -base64 32
NEXTAUTH_SECRET=你的_nextauth_secret

# 應用程式的基本 URL
# 開發環境：http://localhost:3000
# 正式環境：https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# 活動設定
# 此活動的唯一識別碼（用於 QR Code 格式）
# QR Code 格式：EVENT_ID:票券後七碼
# 範例：票券 GOOGA260000000 會生成 EVENT001:0000000
EVENT_ID=EVENT001
